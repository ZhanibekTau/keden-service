APP_NAME=keden-service
HOSTNAME=keden-service_host
APP_VERSION=1.0
SERVER_ADDRESS=:8080
HANDLER_TIMEOUT=30

# JWT
JWT_SECRET=your-secret-key-change-this-to-random-64-chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=keden_broker
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_THIS_PASSWORD
DB_LOGGING=true
DB_MAX_OPEN_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=10

# RabbitMQ
RABBIT_HOST=localhost
RABBIT_LOGIN=admin
RABBIT_PASSWORD=CHANGE_THIS_PASSWORD
RABBIT_PORT=5672

# S3 (MinIO)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=keden-documents
S3_REGION=us-east-1
S3_USE_SSL=false

# AI Service
AI_SERVICE_URL=http://localhost:5000/api/process
AI_SERVICE_TIMEOUT=120s

# Admin
ADMIN_EMAIL=admin@keden.kz
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
